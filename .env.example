# ── Supabase connection ──────────────────────────────────────────────────────
# Required: your Supabase project URL
SUPABASE_URL=

# Required for store (privileged writes).  Must be the service-role key.
# Do NOT substitute SUPABASE_ANON_KEY here – anon credentials cannot write
# to server-side tables that are protected by Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Required for auth token lookup (verifying athlete JWT tokens).
# SUPABASE_SERVICE_ROLE_KEY is preferred and will be used if set.
# If only SUPABASE_ANON_KEY is provided the server will still start but a
# warning is logged and store operations will fail until the service-role
# key is also set.
SUPABASE_ANON_KEY=

# ── Backend application ───────────────────────────────────────────────────────
# Comma-separated list of admin email addresses.
UNLXCK_ADMIN_EMAILS=ops@example.com

# Comma-separated list of allowed CORS origins for the API.
APP_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Set to 1 to enable demo mode (no writes, stubbed responses).
UNLXCK_DEMO_MODE=0

# ── Stage 2 automation (optional) ────────────────────────────────────────────
# Stage 1 (fight-camp plan generation) runs entirely locally without OpenAI.
# Stage 2 (plan finalization/repair) is OPTIONAL and requires OpenAI when
# automated.  Leave OPENAI_API_KEY blank to disable automated Stage 2; the
# API will return HTTP 503 on automated Stage 2 requests and operators can
# use the manual review workflow instead.
OPENAI_API_KEY=

# OpenAI model to use for Stage 2 finalization (default: gpt-5-mini).
UNLXCK_STAGE2_MODEL=gpt-5-mini

# Seconds to wait for a Stage 2 OpenAI response before timing out (default: 90).
UNLXCK_STAGE2_TIMEOUT_SECONDS=90

# Maximum output tokens for Stage 2 model responses (default: unlimited).
UNLXCK_STAGE2_MAX_OUTPUT_TOKENS=6000
