    "option_enum_pattern": "\\b(?:option\\s+[a-c]|[a-c][\\):])",
    "weekday_heading": "^(?:mon(?:day)?|tue(?:s(?:day)?)?|wed(?:nesday)?|thu(?:r(?:sday)?)?|fri(?:day)?|sat(?:urday)?|sun(?:day)?)(?:\\b|[\\s:\\-|])",
    "numbered_session_heading": "^(?:session|day)\\s+\\d+(?:\\s*[:\\-|]|\\s*$)"
