    "operational_guardrail_pattern": "\\b(?:if|when|unless|tomorrow|today|hours?|48|24|pain|symptom|worse|stop|reassess|pivot|rule|rules|reduce|drop|cut|switch|replace|skip)\\b",
    "weight_cut_patterns": [
      "\\bweight[- ]cut\\b",
      "\\bweight making\\b",
      "\\bweigh[- ]in\\b",
      "\\bcut stress\\b",
      "\\bdehydrat",
      "\\brefeed\\b",
      "\\brehydrat"
    ],
    "weight_cut_none_patterns": [
      "\\bweight\\s*cut\\b.{0,40}\\bnone active\\b",
      "\\bno active weight[-\\s]*cut\\b",
      "\\brecovery tolerance is standard\\b"
    ],
    "overstyled_patterns": [
      "\\bdeath march\\b",
      "\\bsmash\\s*&\\s*dash\\b",
      "\\bbully\\b",
      "\\bframe-and-pop\\b",
      "\\bclinch-fighter\\b",
      "\\brope-a-dope\\b",
      "\\bdynamic plank-to-punch\\b",
      "\\bankle snap bounce\\b",
      "\\bhand-fight emom\\b"
