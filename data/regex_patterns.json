      "\\bstay motivated\\b",
      "\\bstay positive\\b",
      "\\bbelieve in yourself\\b",
      "\\bpush yourself\\b"
    ],
    "hedged_adjustment_patterns": [
      "^\\s*(?:[-*\\u2022]+\\s*)?consider\\b",
      "\\bit may be best to\\b",
      "\\bit might be best to\\b",
      "\\byou may want to\\b",
      "\\byou might want to\\b",
      "\\bcould be worth\\b",
      "\\btry to\\b"
    ],
    "adjustment_context_pattern": "\\b(?:reduce|drop|cut|modify|adjust|swap|replace|skip|avoid|rest|recover|recovery|volume|intensity|load|pain|fatigue|soreness|workload|pivot)\\b",
    "empty_safety_patterns": [
